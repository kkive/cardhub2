# --- Database (host-local dev) ---
DATABASE_URL="mysql://cards:cards@localhost:3306/cards_hub"

# --- Redis (host-local dev) ---
REDIS_URL="redis://localhost:6379"

# --- Meilisearch (host-local dev) ---
MEILI_HOST="http://localhost:7700"
MEILI_API_KEY="dev-master-key"

# --- Docker overrides (used by docker-compose.yml containers) ---
# These override the Docker-network defaults when running the full stack.
# Leave commented to use defaults (mysql:3306, redis:6379, meilisearch:7700).
# DOCKER_DATABASE_URL="mysql://cards:cards@mysql:3306/cards_hub"
# DOCKER_REDIS_URL="redis://redis:6379"
# DOCKER_MEILI_HOST="http://meilisearch:7700"

# --- App ---
NODE_ENV=development
PORT=3000

# --- Auth / Passkey ---
PASSKEY_RP_NAME="Cards hub"
PASSKEY_RP_ID="localhost"
PASSKEY_ORIGIN="http://localhost:8000"
ADMIN_EMAIL="admin@cardshub.local"
ADMIN_PASSWORD="admin123456"
JWT_SECRET="change-me-to-a-random-secret"

# --- Frontend Dev Proxy ---
API_PROXY_TARGET="http://localhost:3000"

# --- Storage ---
STORAGE_DIR="./storage"
# Docker containers ignore STORAGE_DIR above; override only if you need a
# different path inside the container (default: /app/storage).
# DOCKER_STORAGE_DIR="/app/storage"

# --- Meilisearch Index ---
MEILI_CARDS_INDEX="cards"

# --- Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- YiPay ---
YIPAY_SECRET=""
