# =============================================================
# Cards hub - Production Environment
# =============================================================
# Copy to .env on the production server. NEVER commit .env to git.
#
# Production uses a single Docker Hub image: <namespace>/cards-hub:<tag>
# The app container runs API + worker + web static service together.
#
# Lines marked [MUST CHANGE] require real values before first deploy.
# Lines marked [optional] can be left as-is for most setups.
# =============================================================

# --- Docker Hub ------------------------------------------------
DOCKERHUB_NAMESPACE=kanggejie
IMAGE_TAG=v1

# --- MySQL ------------------------------------------------------
# [MUST CHANGE] Set strong passwords before first deploy.
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=cards_hub
MYSQL_USER=cards
MYSQL_PASSWORD=change-me-cards-password

# --- Meilisearch -----------------------------------------------
# [MUST CHANGE] Set a real secret. Used by Meilisearch and the API.
MEILI_MASTER_KEY=change-me-meili-master-key

# --- API / Worker shared ---------------------------------------
# Used when MEILI_API_KEY is not set explicitly (falls back to MEILI_MASTER_KEY)
# MEILI_API_KEY=change-me-meili-api-key

# --- WebAuthn / Passkeys ---------------------------------------
# [MUST CHANGE] Must match your production domain (HTTPS required).
PASSKEY_RP_ID=example.com
PASSKEY_ORIGIN=https://example.com

# --- Admin seed ------------------------------------------------
# First admin is auto-created on API startup if no admin exists.
# After that, this env var is ignored (never resets password).
# [MUST CHANGE] Set a strong password.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-first-admin-password

# --- JWT -------------------------------------------------------
# [MUST CHANGE] Set a long random string (e.g. openssl rand -hex 32).
JWT_SECRET=change-me-jwt-secret

# --- Storage (inside containers) -------------------------------
# DOCKER_STORAGE_DIR=/app/storage          # [optional] default, usually no change
# DOCKER_DATABASE_URL=mysql://cards:PASSWORD@mysql:3306/cards_hub
# DOCKER_REDIS_URL=redis://redis:6379
# DOCKER_MEILI_HOST=http://meilisearch:7700

# --- Host nginx upstream / port bindings ----------------------
# API: always internal (host nginx reverse-proxies to it).
# WEB: bind to 0.0.0.0 to access the frontend directly at
#      http://SERVER_IP:8000, or keep 127.0.0.1 if using host nginx.
API_BIND=127.0.0.1
API_PORT=3000
WEB_BIND=0.0.0.0
WEB_PORT=8000

# --- Database wait (entrypoint) --------------------------------
# The app container waits for the database TCP port to become
# reachable before running Prisma migrations.
# DB_WAIT_TIMEOUT_SECONDS=120
# DB_WAIT_INTERVAL_SECONDS=2

# --- Service wait (entrypoint) ---------------------------------
# The app container also waits for Redis and Meilisearch TCP ports.
# SERVICE_WAIT_TIMEOUT_SECONDS=120
# SERVICE_WAIT_INTERVAL_SECONDS=2

# --- Payment (optional) ----------------------------------------
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# YIPAY_SECRET=...
